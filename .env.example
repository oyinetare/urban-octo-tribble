# Application
PROJECT_NAME="urban-octo-tribble"
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/urban-octo-tribble
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Security
# to get SECRET_KEY run:
# openssl rand -hex 32
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# MinIO / S3 Storage
# MINIO_ENDPOINT=localhost:9000
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_DOCUMENTS_BUCKET_NAME=documents
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,txt,doc,docx,md,xlsx,pptx

# Celery
CELERY_BROKER_URL="redis://changeme:6379/0"
CELERY_RESULT_BACKEND="redis://changeme:6379/0"
CELERY_TASK_SERIALIZER="json"
CELERY_RESULT_SERIALIZER="json"
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE= "UTC"
CELERY_ENABLE_UTC=True
CELERY_WORKER=True

# Qdrant Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents
QDRANT_API_KEY=

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# Search
DEFAULT_SEARCH_LIMIT=5
DEFAULT_SCORE_THRESHOLD=0.7

# LLM
# Primary LLM provider: 'anthropic' or 'ollama'
LLM_PROVIDER=ollama
LLM_FALLBACK_ENABLED=false

# Anthropic
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# Ollama
# OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434 # For Docker to reach host
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# RAG Configuration
RAG_MAX_CONTEXT_CHUNKS=5
RAG_MIN_SIMILARITY_SCORE=0.6
RAG_SYSTEM_PROMPT="You are a helpful AI assistant that answers questions based on the provided document context.

Rules:
1. Answer ONLY based on the provided context
2. If the context doesn't contain enough information, say so
3. Cite your sources by referencing [Source N] where N is the chunk number
4. Be precise and concise
5. If asked about multiple documents, clearly distinguish between sources"

# Hybrid Search
HYBRID_SEARCH_ENABLED=true
HYBRID_RRF_K=60
HYBRID_FETCH_MULTIPLIER=4
FTS_LANGUAGE=english

# Event Streaming (Kafka/Redpanda)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_EVENTS_TOPIC=document-events
KAFKA_ANALYTICS_TOPIC=analytics-events
KAFKA_CONSUMER_GROUP=urban-octo-tribble-consumers
KAFKA_ENABLE_EVENTS=true

# Sharding Configuration
SHARDING_ENABLED=true
SHARDING_VIRTUAL_NODES=150
SHARDING_STRATEGY=user

# Define your shards (format: "id:weight,id:weight,...")
SHARD_NODES=shard-0:1,shard-1:1,shard-2:1
