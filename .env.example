# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/urban-octo-tribble

# Environment
ENVIRONMENT=development

# Security
# to get SECRET_KEY run:
# openssl rand -hex 32
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
